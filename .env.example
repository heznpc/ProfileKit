# GitHub token(s) used by all /api/* endpoints that hit the GitHub API
# (stats, languages, pin, reviews, stack).
#
# A single token bottlenecks at 5000 GraphQL points per hour — that's
# roughly 1000 stats calls per hour in the worst case. Heavy readers
# (popular README embeds) blow through this in minutes. If you're
# self-hosting, set up a token pool. src/common/github-token.js reads
# any of the three shapes below; duplicates across them are removed,
# so you can mix and match.
#
# A token needs the `public_repo` scope (or nothing at all for public
# stats — fine-grained "no access" tokens still count against your
# hourly budget and are the recommended minimum).

# --- Option A: single token (simplest) ---
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# --- Option B: comma-separated pool ---
# GITHUB_TOKENS=ghp_aaa,ghp_bbb,ghp_ccc

# --- Option C: numbered pool (GITHUB_TOKEN_1..GITHUB_TOKEN_31) ---
# GITHUB_TOKEN_1=ghp_aaa
# GITHUB_TOKEN_2=ghp_bbb
# GITHUB_TOKEN_3=ghp_ccc
